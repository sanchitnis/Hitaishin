# Hitaishin — .gitignore

# ============================================================
# PERSONAL PROFILES — never commit to public repos
# ============================================================
profiles/*
!profiles/_mentee-profile-template.md
!profiles/README.md

# ============================================================
# GTD PERSONAL DATA — weekly reviews and project files contain
# personal information; keep private unless you intend to share
# ============================================================
gtd/weekly-reviews/
gtd/projects/*.md
!gtd/projects/_project-template.md
gtd/*.bak

# ============================================================
# OS AND EDITOR FILES
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# ============================================================
# PYTHON (if scripts/ folder is added)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.env
.venv
venv/
ENV/
*.log

# ============================================================
# NODE (if JS tooling is added)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
package-lock.json

# ============================================================
# BACKUP FILES (created by GTD scripts)
# ============================================================
*.bak
*.backup
*.orig

# ============================================================
# SKILL PACKAGE FILES (generated; not source)
# ============================================================
*.skill
*.zip

# ============================================================
# SECRETS AND CREDENTIALS
# ============================================================
.env
.env.local
.env.*.local
secrets.json
credentials.json
token.json
